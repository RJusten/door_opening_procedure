<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Türoffnungsprozedere Innenangriff</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #0f172a;
        color: white;
      }
      .wrap {
        padding: 24px;
        overflow: auto;
      }
      h1 {
        margin: 0 0 24px 0;
        font-size: 28px;
      }
      .chart {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        min-width: 1200px;
      }
      .row {
        display: flex;
        justify-content: center;
        gap: 80px;
        width: 100%;
      }
      .box, .decision {
        background: #1f2937;
        border: 1px solid #475569;
        border-radius: 14px;
        padding: 14px 18px;
        min-width: 260px;
        max-width: 320px;
        text-align: center;
        box-shadow: 0 8px 22px rgba(0,0,0,0.25);
      }
      .blue { background: #1d4ed8; }
      .red { background: #b91c1c; }
      .green { background: #166534; }
      .orange { background: #92400e; }
      .brown { background: #7c2d12; }
      .teal { background: #0f766e; }
      .decision {
        background: #334155;
        font-weight: bold;
      }
      .connector {
        font-size: 24px;
        line-height: 1;
        color: #94a3b8;
      }
      .branch {
        display: flex;
        justify-content: space-between;
        gap: 80px;
        width: 100%;
      }
      .column {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        flex: 1;
      }
      .label {
        color: #cbd5e1;
        font-weight: bold;
        margin-bottom: -8px;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1>Türoffnungsprozedere Innenangriff</h1>

      <div class="chart">
        <div class="box">Türoffnungsprozedere Innenangriff</div>
        <div class="connector">↓</div>
        <div class="decision">Öffnungsrichtung?</div>
        <div class="connector">↓</div>

        <div class="branch">
          <div class="column">
            <div class="label">Nach innen</div>
            <div class="box blue">Positionierung: TF Türgriffseite / SF Scharnierseite</div>
            <div class="connector">↓</div>
            <div class="box">Bandschlinge am Türgriff anbringen / Rauchverschluss setzen</div>
            <div class="connector">↓</div>
            <div class="box">Truppführer kündigt Öffnen an</div>
            <div class="connector">↓</div>
            <div class="box">Truppführer öffnet die Tür kontrolliert</div>
          </div>

          <div class="column">
            <div class="label">Nach außen</div>
            <div class="box red">Positionierung: TF Scharnierseite / SF Türgriffseite</div>
            <div class="connector">↓</div>
            <div class="box">Bandschlinge am Türgriff anbringen</div>
            <div class="connector">↓</div>
            <div class="box">Truppführer kündigt Öffnen an</div>
            <div class="connector">↓</div>
            <div class="box">Tür kontrolliert aufziehen und mit Fuß sichern</div>
            <div class="connector">↓</div>
            <div class="box">Rauchverschluss setzen</div>
          </div>
        </div>

        <div class="connector">↓</div>
        <div class="box teal">Truppführer tritt unter Deckung des Strahlrohrführers in den Raum</div>
        <div class="connector">↓</div>
        <div class="decision">Personen im Nahbereich?</div>

        <div class="branch">
          <div class="column">
            <div class="label">Ja</div>
            <div class="box orange">Personenrettung einleiten</div>
            <div class="connector">↓</div>
            <div class="box brown">Tür schließen</div>
            <div class="connector">↓</div>
            <div class="box brown">Truppführer kündigt Öffnen an und öffnet die Tür</div>
          </div>

          <div class="column">
            <div class="label">Nein</div>
            <div class="decision">Rauch sichtbar?</div>
            <div class="connector">↓</div>
            <div class="decision">Feuerschein sichtbar?</div>
            <div class="connector">↓</div>
            <div class="box">Raumgeometrie beurteilen</div>
            <div class="connector">↓</div>
            <div class="box green">Trupp geht in den Brandraum vor</div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
