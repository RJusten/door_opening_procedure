<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Türoffnungsprozedere Innenangriff</title>
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://unpkg.com/reactflow/dist/umd/index.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/reactflow/dist/style.css" />
    <style>
      html, body, #root {
        margin: 0;
        width: 100%;
        height: 100%;
        font-family: Arial, sans-serif;
        background: #0f172a;
      }

      .app {
        width: 100%;
        height: 100%;
      }

      .titlebar {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 10;
        background: rgba(15, 23, 42, 0.9);
        color: white;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 8px 24px rgba(0,0,0,0.25);
      }

      .titlebar h1 {
        margin: 0 0 4px 0;
        font-size: 18px;
      }

      .titlebar p {
        margin: 0;
        font-size: 13px;
        color: #cbd5e1;
      }
    </style>
  </head>
  <body>
    <div id="root"></div>

    <script type="text/babel">
      const {
        ReactFlow,
        Background,
        Controls,
        MiniMap,
        MarkerType
      } = window.ReactFlow;
      const { useMemo } = React;

      function App() {
        const nodes = useMemo(() => [
          {
            id: "A",
            position: { x: 420, y: 20 },
            data: { label: "Türoffnungsprozedere Innenangriff" },
            style: {
              background: "#111827",
              color: "#fff",
              border: "1px solid #334155",
              borderRadius: "14px",
              padding: "10px",
              width: 260,
              textAlign: "center",
              fontWeight: "700"
            }
          },
          {
            id: "B",
            position: { x: 470, y: 120 },
            data: { label: "Öffnungsrichtung?" },
            style: {
              background: "#1e293b",
              color: "#fff",
              border: "1px solid #475569",
              borderRadius: "14px",
              width: 160,
              textAlign: "center",
              fontWeight: "600"
            }
          },

          {
            id: "C1",
            position: { x: 90, y: 240 },
            data: { label: "Positionierung: TF Türgriffseite / SF Scharnierseite" },
            style: nodeStyle("#1d4ed8")
          },
          {
            id: "C2",
            position: { x: 90, y: 340 },
            data: { label: "Bandschlinge am Türgriff anbringen / Rauchverschluss setzen" },
            style: nodeStyle()
          },
          {
            id: "C3",
            position: { x: 90, y: 440 },
            data: { label: "Truppführer kündigt Öffnen an" },
            style: nodeStyle()
          },
          {
            id: "C4",
            position: { x: 90, y: 540 },
            data: { label: "Truppführer öffnet die Tür kontrolliert" },
            style: nodeStyle()
          },

          {
            id: "D1",
            position: { x: 760, y: 240 },
            data: { label: "Positionierung: TF Scharnierseite / SF Türgriffseite" },
            style: nodeStyle("#b91c1c")
          },
          {
            id: "D2",
            position: { x: 760, y: 340 },
            data: { label: "Bandschlinge am Türgriff anbringen" },
            style: nodeStyle()
          },
          {
            id: "D3",
            position: { x: 760, y: 440 },
            data: { label: "Truppführer kündigt Öffnen an" },
            style: nodeStyle()
          },
          {
            id: "D4",
            position: { x: 760, y: 540 },
            data: { label: "Tür kontrolliert aufziehen und mit Fuß sichern" },
            style: nodeStyle()
          },
          {
            id: "D5",
            position: { x: 760, y: 640 },
            data: { label: "Rauchverschluss setzen" },
            style: nodeStyle()
          },

          {
            id: "E1",
            position: { x: 420, y: 760 },
            data: { label: "Truppführer tritt unter Deckung des Strahlrohrführers in den Raum" },
            style: nodeStyle("#0f766e", 320)
          },

          {
            id: "P1",
            position: { x: 420, y: 880 },
            data: { label: "Personen im Nahbereich?" },
            style: decisionStyle()
          },
          {
            id: "P1a",
            position: { x: 120, y: 1000 },
            data: { label: "Personenrettung einleiten" },
            style: nodeStyle("#92400e")
          },

          {
            id: "P2",
            position: { x: 420, y: 1120 },
            data: { label: "Rauch sichtbar?" },
            style: decisionStyle()
          },
          {
            id: "P2a",
            position: { x: 120, y: 1240 },
            data: { label: "Rauchgaskühlung durchführen" },
            style: nodeStyle("#92400e")
          },

          {
            id: "P3",
            position: { x: 420, y: 1360 },
            data: { label: "Feuerschein sichtbar?" },
            style: decisionStyle()
          },
          {
            id: "P3a",
            position: { x: 760, y: 1480 },
            data: { label: "Brandbekämpfung einleiten" },
            style: nodeStyle("#166534")
          },

          {
            id: "P4",
            position: { x: 420, y: 1480 },
            data: { label: "Raumgeometrie beurteilen" },
            style: nodeStyle()
          },
          {
            id: "P5",
            position: { x: 420, y: 1600 },
            data: { label: "Trupp geht in den Brandraum vor" },
            style: nodeStyle("#166534", 250)
          },

          {
            id: "Z",
            position: { x: 120, y: 780 },
            data: { label: "Tür schließen" },
            style: nodeStyle("#7c2d12", 170)
          },
          {
            id: "R",
            position: { x: 120, y: 660 },
            data: { label: "Truppführer kündigt Öffnen an und öffnet die Tür" },
            style: nodeStyle("#7c2d12", 250)
          }
        ], []);

        const edges = useMemo(() => [
          edge("A", "B"),

          edge("B", "C1", "Nach innen"),
          edge("C1", "C2"),
          edge("C2", "C3"),
          edge("C3", "C4"),
          edge("C4", "E1"),

          edge("B", "D1", "Nach außen"),
          edge("D1", "D2"),
          edge("D2", "D3"),
          edge("D3", "D4"),
          edge("D4", "D5"),
          edge("D5", "E1"),

          edge("E1", "P1"),
          edge("P1", "P1a", "Ja"),
          edge("P1a", "Z"),
          edge("P1", "P2", "Nein"),

          edge("P2", "P2a", "Ja"),
          edge("P2a", "Z"),
          edge("P2", "P3", "Nein"),

          edge("P3", "P3a", "Ja"),
          edge("P3a", "P5"),
          edge("P3", "P4", "Nein"),
          edge("P4", "P5"),

          edge("Z", "R"),
          edge("R", "E1")
        ], []);

        return (
          <div className="app">
            <div className="titlebar">
              <h1>Türoffnungsprozedere</h1>
              <p>Interaktive Startversion mit React Flow</p>
            </div>
            <ReactFlow nodes={nodes} edges={edges} fitView>
              <MiniMap />
              <Controls />
              <Background />
            </ReactFlow>
          </div>
        );
      }

      function nodeStyle(bg = "#1f2937", width = 240) {
        return {
          background: bg,
          color: "#fff",
          border: "1px solid rgba(255,255,255,0.18)",
          borderRadius: "14px",
          padding: "10px",
          width,
          textAlign: "center",
          fontSize: "13px",
          lineHeight: "1.3",
          boxShadow: "0 8px 22px rgba(0,0,0,0.22)"
        };
      }

      function decisionStyle() {
        return {
          background: "#334155",
          color: "#fff",
          border: "1px solid rgba(255,255,255,0.18)",
          borderRadius: "14px",
          padding: "10px",
          width: 220,
          textAlign: "center",
          fontSize: "13px",
          fontWeight: "700",
          boxShadow: "0 8px 22px rgba(0,0,0,0.22)"
        };
      }

      function edge(source, target, label) {
        return {
          id: `${source}-${target}`,
          source,
          target,
          label,
          markerEnd: {
            type: MarkerType.ArrowClosed
          },
          style: {
            strokeWidth: 2
          },
          labelStyle: {
            fill: "#e2e8f0",
            fontWeight: 700
          }
        };
      }

      ReactDOM.createRoot(document.getElementById("root")).render(<App />);
    </script>
  </body>
</html>
